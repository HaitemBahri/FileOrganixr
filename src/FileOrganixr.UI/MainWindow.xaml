<Window x:Class="FileOrganixr.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FileOrganixr"
        Height="820"
        Width="1320"
        MinHeight="640"
        MinWidth="980">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="Y" Modifiers="Alt" Command="{Binding ApprovalActions.ApproveCommand}"/>
        <KeyBinding Key="N" Modifiers="Alt" Command="{Binding ApprovalActions.RejectCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding Notification.DismissCommand}"/>
    </Window.InputBindings>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,10"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="FileOrganixr Request Monitor"/>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="10"
                CornerRadius="4"
                Background="#FFF4F5F7"
                BorderBrush="#FFCBD5E1"
                BorderThickness="1"
                Visibility="{Binding Notification.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           FontWeight="SemiBold"
                           Text="{Binding Notification.SeverityText}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,8,4"
                           Text="{Binding Notification.Message}"/>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Grid.RowSpan="2"
                        Command="{Binding Notification.DismissCommand}"
                        Content="Dismiss"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Foreground="#FF475569"
                           Text="{Binding Notification.Details}"
                           TextWrapping="Wrap"
                           Visibility="{Binding Notification.HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" FocusManager.FocusedElement="{Binding ElementName=RequestSearchBox}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Requests">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Row="0"
                             Grid.Column="0"
                             x:Name="RequestSearchBox"
                             Margin="0,0,0,8"
                             AutomationProperties.Name="Request Search"
                             VerticalContentAlignment="Center"
                             ToolTip="Search by file, path, folder, rule, note, or ID"
                             Text="{Binding Requests.SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="2"
                              Margin="0,0,0,8"
                              ItemsSource="{Binding Requests.StatusFilterOptions}"
                              SelectedItem="{Binding Requests.SelectedStatusFilter, Mode=TwoWay}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="4"
                              Margin="0,0,0,8"
                              ItemsSource="{Binding Requests.SortOptions}"
                              SelectedItem="{Binding Requests.SelectedSortOption, Mode=TwoWay}"/>

                    <Button Grid.Row="0"
                            Grid.Column="6"
                            Margin="0,0,0,8"
                            Command="{Binding Requests.ClearFiltersCommand}"
                            Content="Clear"/>

                    <TextBlock Grid.Row="0"
                               Grid.Column="8"
                               Margin="0,0,0,8"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="#FF475569"
                               Text="{Binding Requests.ResultCountText}"/>

                    <Grid Grid.Row="1" Grid.ColumnSpan="9">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Requests.View}"
                                  SelectedItem="{Binding Requests.SelectedItem, Mode=TwoWay}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status"
                                                    Width="120"
                                                    Binding="{Binding CurrentStatusText}"/>
                                <DataGridTextColumn Header="File"
                                                    Width="2*"
                                                    Binding="{Binding FileName}"/>
                                <DataGridTextColumn Header="Folder"
                                                    Width="*"
                                                    Binding="{Binding MonitoredFolderName}"/>
                                <DataGridTextColumn Header="Rule"
                                                    Width="*"
                                                    Binding="{Binding RuleName}"/>
                                <DataGridTextColumn Header="Last Update (UTC)"
                                                    Width="180"
                                                    Binding="{Binding LastStatusTimestampUtc, StringFormat={}{0:u}}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="#CCFFFFFF"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding Requests.IsEmptyStateVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock FontStyle="Italic"
                                       Foreground="#FF475569"
                                       Text="{Binding Requests.EmptyStateText}"/>
                        </Border>
                    </Grid>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Request Details">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="Status:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding RequestDetails.CurrentStatus}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="File:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding RequestDetails.FileName}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="Folder:"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding RequestDetails.MonitoredFolderName}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="Rule:"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Text="{Binding RequestDetails.RuleName}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" FontWeight="SemiBold" Text="Path:"/>
                        <TextBlock Grid.Row="4" Grid.Column="1"
                                   Margin="0,0,0,6"
                                   Text="{Binding RequestDetails.FullPath}"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" FontWeight="SemiBold" Text="Latest Note:"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Margin="0,0,0,0"
                                   Text="{Binding RequestDetails.LatestNote}"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Margin="0,8,0,0"
                                   FontStyle="Italic"
                                   Foreground="#FF64748B"
                                   Text="{Binding RequestDetails.SelectionHintText}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Margin="0,8,0,8" Header="Approvals">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,8,0"
                                MinWidth="110"
                                IsEnabled="{Binding ApprovalActions.CanTakeAction}"
                                Command="{Binding ApprovalActions.ApproveCommand}"
                                ToolTip="Alt+Y"
                                Content="_Approve"/>
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                MinWidth="110"
                                IsEnabled="{Binding ApprovalActions.CanTakeAction}"
                                Command="{Binding ApprovalActions.RejectCommand}"
                                ToolTip="Alt+N"
                                Content="_Reject"/>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center"
                                   Text="{Binding ApprovalActions.LastActionMessage}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Status History (UTC)">
                    <DataGrid Margin="8"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding RequestDetails.History}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status"
                                                Width="130"
                                                Binding="{Binding Status}"/>
                            <DataGridTextColumn Header="Timestamp"
                                                Width="200"
                                                Binding="{Binding TimestampUtc, StringFormat={}{0:u}}"/>
                            <DataGridTextColumn Header="Note"
                                                Width="*"
                                                Binding="{Binding Note}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Diagnostics">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Host:"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" Text="{Binding RuntimeState.HostStateText}"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Margin="0,0,8,4" FontWeight="SemiBold" Text="Errors:"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Margin="0,0,0,4" Text="{Binding RuntimeState.ErrorCount}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Config:"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="4"
                               Margin="0,0,0,4"
                               Text="{Binding RuntimeState.EffectiveConfigPath}"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Last Event:"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Grid.ColumnSpan="4"
                               Margin="0,0,0,4"
                               Text="{Binding RuntimeState.LastEventText}"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" FontWeight="SemiBold" Text="Event Time:"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,0" Text="{Binding RuntimeState.LastEventTimestampText}"/>

                    <TextBlock Grid.Row="3" Grid.Column="3" Margin="0,0,8,0" FontWeight="SemiBold" Text="Action Msg:"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="4"
                               Margin="0,0,0,0"
                               Text="{Binding ApprovalActions.LastActionMessage}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <GroupBox Grid.Column="2" Header="Settings and Config">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Effective Path:"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Margin="0,0,0,4"
                               Text="{Binding SettingsPanel.EffectiveConfigPath}"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Override Var:"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" Text="{Binding SettingsPanel.OverrideEnvironmentVariableName}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Override State:"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,4" Text="{Binding SettingsPanel.OverrideStateText}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,4" FontWeight="SemiBold" Text="Override Value:"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,0,0,4"
                               Text="{Binding SettingsPanel.OverrideValue}"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="#FF475569"
                                   Text="{Binding SettingsPanel.OverrideGuidance}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,0,0,6"
                                   Foreground="#B91C1C"
                                   Text="{Binding SettingsPanel.LastRefreshError}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding SettingsPanel.HasRefreshError, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Button Width="120"
                                HorizontalAlignment="Left"
                                Command="{Binding SettingsPanel.RefreshCommand}"
                                Content="Refresh Settings"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
